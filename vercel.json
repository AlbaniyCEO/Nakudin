{
  "installCommand": "npm install -g pnpm@10.26.1 && pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run typecheck:libs && pnpm --filter @workspace/nakudin run build",
  "outputDirectory": "artifacts/nakudin/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/((?!assets|favicon\\.svg|manifest\\.json|robots\\.txt|sw\\.js).*)", "destination": "/index.html" }
  ]
}